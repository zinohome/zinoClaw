{
  "meta": {
    "lastTouchedVersion": "2026.3.2",
    "lastTouchedAt": "2026-03-04T03:01:41.127279Z"
  },
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard"
      },
      "workspace": "/config/.openclaw/workspace",
      "model": {
        "primary": "newapi/gpt-4.1"
      },
      "heartbeat": {
        "every": "30m",
        "activeHours": "08:00-23:00"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "your-gateway-token"
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": true,
      "allowedOrigins": [
        "http://localhost"
      ]
    }
  },
  "channels": {
    "slack": {
      "mode": "socket",
      "enabled": true,
      "botToken": "xoxb-your-bot-token",
      "appToken": "xapp-your-app-token",
      "groupPolicy": "open",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "U_YOUR_SLACK_USER_ID"
      ]
    }
  },
  "plugins": {
    "entries": {}
  },
  "memory": {
    "backend": "qmd",
    "qmd": {
      "command": "/usr/local/bin/qmd",
      "paths": [
        {
          "path": "/config/.openclaw/workspace",
          "name": "workspace",
          "pattern": "**/*.md"
        }
      ]
    }
  },
  "browser": {
    "executablePath": "/usr/bin/chromium",
    "headless": true,
    "noSandbox": true
  },
  "models": {
    "mode": "merge",
    "providers": {
      "newapi": {
        "apiKey": "sk-your-api-key",
        "baseUrl": "https://your-api-base-url/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "gpt-4.1",
            "name": "gpt-4.1",
            "input": [
              "text"
            ],
            "contextWindow": 128000,
            "maxTokens": 128000
          }
        ]
      }
    }
  }
}
